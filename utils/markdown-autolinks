#!/bin/sh
[ "$MAL_TEST" != y ] || {
	MAL_EXPECT=11625826
	MAL_TEST=
	test \
		"$($0 `command -v $0` | sed '1,/^exit$/d' | sha1sum | head -c 8)" \
		= \
		"${MAL_EXPECT:?}" \
	&& { echo tests passsed; exit 0; } \
	|| { echo tests failed; exit 1; }
}

make_link() {
	case "$1" in
		wp) make_link wp-en "$2" ;;
		wt) make_link wt-en "$2" ;;
		wp-*) printf "https://${1#wp-}.wikpedia.org/wiki/%s\n" \
			"`printf %s "$2" | uri-encode`" ;;
		wt-*) printf "https://${1#wt-}.wiktionary.org/wiki/%s\n" \
			"`printf %s "$2" | uri-encode`" ;;
		arXiv|arxiv) printf "https://arxiv.org/abs/$2" ;;
	esac
}

md="$(cat $1)" && echo "$md" && echo &&
	echo "$md" |
	sed '1,/^exit$/d' |
	grep -oP '(?<!\\)\[\K[^:\]]+:[^\]]+(?=\])' |
		while read ref; do
			prefix="${ref%%:*}" page="${ref#*:}"
			echo "$md" | grep -qF "[$prefix:$page]: " ||
				printf "[%s] %s\n" \
					"$prefix:$page" \
					"$(make_link "$prefix" "$page")"
		done | LANG=C sort | uniq

exit
